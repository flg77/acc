# examples/acc_autoresearcher/.env.example
# =============================================================================
# Per-example overrides sourced by ./run.sh into the runner shell.
#
#   cp examples/acc_autoresearcher/.env.example examples/acc_autoresearcher/.env
#   $EDITOR examples/acc_autoresearcher/.env
#
# IMPORTANT — LLM connection variables (ACC_LLM_BACKEND, ACC_OPENAI_*,
# ACC_OLLAMA_*, ACC_ANTHROPIC_*) MUST live in deploy/.env, NOT here.
# The compose file's env_file directive points only at deploy/.env, so
# values set here do NOT reach the agent containers.  Use:
#
#     ./env/use.sh anthropic                     # for hosted Claude
#     ./env/use.sh llama-3.2-1B-Instruct-FP8     # for local vLLM
#     $EDITOR deploy/.env                         # paste API keys
#
# This file is for autoresearcher-runner knobs (iteration cap, critic
# threshold, verify thresholds) and the BRAVE_API_KEY / browser-harness
# settings the dedicated MCP containers receive via their env: blocks.
# =============================================================================


# -----------------------------------------------------------------------------
# Stack identity + bring-up
# -----------------------------------------------------------------------------

ACC_COLLECTIVE_ID=sol-01

# acc-deploy.sh profiles activated on `up`:
#   TUI=true              attaches the acc-tui container so screen 7
#                         shows the cluster panel live.
#   AUTORESEARCHER=true   activates the three real-research MCP
#                         servers (web_browser_harness, web_search_brave,
#                         web_fetch) under the matching compose profile.
#   DETACH=true           run.sh exits after the stack is up.
TUI=true
AUTORESEARCHER=true
DETACH=true


# -----------------------------------------------------------------------------
# LLM backend — REQUIRED.  Pick one and fill in the matching block.
# -----------------------------------------------------------------------------

# Option A — Anthropic API (production-ready; needs paid API key).
# ACC_LLM_BACKEND=anthropic
# ACC_ANTHROPIC_API_KEY=sk-ant-...
# ACC_ANTHROPIC_MODEL=claude-sonnet-4-5

# Option B — OpenShift AI / vLLM (self-hosted; OpenAI-compat).
# ACC_LLM_BACKEND=openai_compat
# ACC_OPENAI_BASE_URL=https://vllm.apps.openshift.example.com/v1
# ACC_OPENAI_API_KEY=replace-with-served-token
# ACC_OPENAI_MODEL=meta-llama/Meta-Llama-3.1-70B-Instruct

# Option C — local Ollama (zero-cost; quality-bound for research).
ACC_LLM_BACKEND=ollama
ACC_OLLAMA_URL=http://localhost:11434
ACC_OLLAMA_MODEL=llama3.1:70b


# -----------------------------------------------------------------------------
# Real-research MCPs — opt-in details
# -----------------------------------------------------------------------------

# browser-harness drives a real browser (Playwright + Chromium).  HIGH risk
# (Cat-A A-018 ceiling check applies); the personas declare
# max_mcp_risk_level: HIGH explicitly.
# Set BROWSER_HARNESS_HEADLESS=false locally to watch the browser at work.
BROWSER_HARNESS_HEADLESS=true

# Brave Search MCP — fallback for keyword-only lookups.
# Free tier: 2k queries / month.  Sign up at https://brave.com/search/api/.
BRAVE_API_KEY=BSA-replace-me

# web_fetch wraps the modelcontextprotocol/servers fetch reference with a
# paywall-detection wrapper (E2).  No API key needed.


# -----------------------------------------------------------------------------
# Iteration loop knobs (E1)
# -----------------------------------------------------------------------------

# Cap on synthesizer→critic→synthesizer revision rounds.  Default 3.
# Bump to 5 only if you have run the iteration-quality experiment (see
# README §  "Iteration-quality experiment") and observed monotonic gains.
ACC_RESEARCH_MAX_ITERATIONS=3

# Critic threshold below which a verdict is NEEDS_REVISE.  Higher = more
# revisions = better quality, more wall-clock + LLM cost.
ACC_RESEARCH_CRITIC_THRESHOLD=0.70

# Self-modifying-personas opt-in.  When true, the critic MAY emit a
# prompt_patch that the arbiter merges into the synthesizer's effective
# prompt for the next iteration.  Cat-A A-021 enforces sanity rules.
ACC_RESEARCH_ENABLE_PROMPT_PATCHES=true


# -----------------------------------------------------------------------------
# Cost cap (E1) — configurable per operator decision (revision 2)
# -----------------------------------------------------------------------------

# Total token budget across the whole plan.  0 = unset = no cap.
# When the cap is hit mid-run, the arbiter refuses further reissues,
# transitions the running step to FAILED, and emits ALERT_ESCALATE.
# A typical full demo run lands ~120k–180k tokens on Anthropic.
ACC_RESEARCH_MAX_RUN_TOKENS=0


# -----------------------------------------------------------------------------
# Output destination (E5 — operator decision: ./runs/<topic>-<date>/)
# -----------------------------------------------------------------------------

# Top-level runs/ directory; gitignored.  run.sh computes
# <topic-slug>-<date> automatically and exports
# ACC_RUN_OUTPUT_DIR before submitting the plan.
ACC_RUNS_ROOT=./runs


# -----------------------------------------------------------------------------
# Verification window (verify.sh)
# -----------------------------------------------------------------------------

# How long verify.sh subscribes to the bus before reporting cluster
# topology + citation coverage.  Bump for slower LLMs.
ACC_VERIFY_DURATION_S=300

# Minimum distinct cluster_ids verify.sh must observe to exit 0.
# The plan dispatches: planner (1) + economist (≥1) + competitor (≥1) +
# strategist (1) + synthesizer (1) + critic (1) = ≥ 5 clusters with
# unique cluster_ids, more if the implementer estimator fans out further.
ACC_VERIFY_MIN_CLUSTERS=5

# Citation re-verification threshold.  At least this fraction of cited
# URLs must have been re-fetched by the critic during the run.  Default
# 0.30 (the critic spot-checks 3-5 of the dozens of citations a typical
# run produces).
ACC_RESEARCH_MIN_VERIFIED_CITATIONS=0.30
