# examples/coding_split_skills/.env.example
# =============================================================================
# Copy this file to ./examples/coding_split_skills/.env and fill in the
# operator-specific values BEFORE running ./run.sh.
#
#   cp examples/coding_split_skills/.env.example examples/coding_split_skills/.env
#   $EDITOR examples/coding_split_skills/.env
#
# run.sh `set -a; source .env; set +a` so any variable here is exported
# into the acc-deploy.sh + acc-cli child processes.
# =============================================================================


# -----------------------------------------------------------------------------
# Stack identity + bring-up
# -----------------------------------------------------------------------------

# Collective the demo runs against.  Defaults to sol-01 — change only
# when running multiple demos in parallel against one NATS cluster.
ACC_COLLECTIVE_ID=sol-01

# acc-deploy.sh profiles activated on `up`:
#   TUI=true        attaches the acc-tui container so screen 7 shows
#                   the cluster panel live.
#   MCP_ECHO=true   activates the diagnostic echo MCP server — every
#                   persona's allowed_mcps lists echo_server.
#   DETACH=true     run.sh exits after the stack is up (otherwise it
#                   tails stack logs).
TUI=true
MCP_ECHO=true
DETACH=true


# -----------------------------------------------------------------------------
# LLM backend — REQUIRED.  Pick exactly one and fill in the matching block.
# -----------------------------------------------------------------------------

# Option A — Anthropic API (production-ready; needs a paid API key).
# ACC_LLM_BACKEND=anthropic
# ACC_ANTHROPIC_API_KEY=sk-ant-...
# ACC_ANTHROPIC_MODEL=claude-sonnet-4-5

# Option B — local Ollama (zero-cost; use a fast model).
ACC_LLM_BACKEND=ollama
ACC_OLLAMA_URL=http://localhost:11434
ACC_OLLAMA_MODEL=llama3.1:8b

# Option C — vLLM / OpenShift AI inference endpoint.
# ACC_LLM_BACKEND=openai_compat
# ACC_OPENAI_BASE_URL=https://vllm.apps.openshift.example.com/v1
# ACC_OPENAI_API_KEY=replace-with-served-token
# ACC_OPENAI_MODEL=meta-llama/Meta-Llama-3.1-8B-Instruct


# -----------------------------------------------------------------------------
# Roles + skills roots — override only when running outside the repo
# -----------------------------------------------------------------------------

# The arbiter's role_resolver (D1) reads ACC_ROLES_ROOT.  Defaults to
# ./roles relative to the working directory, which is the repo root
# when run.sh executes.
ACC_ROLES_ROOT=./roles
ACC_SKILLS_ROOT=./skills


# -----------------------------------------------------------------------------
# Verification window
# -----------------------------------------------------------------------------

# How long verify.sh subscribes to the bus before reporting cluster
# topology.  Bump for slower LLMs.
ACC_VERIFY_DURATION_S=90

# Minimum distinct cluster_ids verify.sh must observe to exit 0.
# The plan dispatches: architect (1) + dependency (1) + implementer
# (≥2) + tester (≥2) + reviewer (1) = ≥5 clusters.  Set lower if
# the LLM aborts mid-run during demo iteration.
ACC_VERIFY_MIN_CLUSTERS=3
