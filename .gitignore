__pycache__/
*.pyc
*.pyo
.env
.claude/
.coverage
cover.out
.env.local
.env.*.local

# acc-webgui htpasswd credentials — bcrypt password hashes for the
# `htpasswd` auth mode.  Bound into the container at /app/acc-webgui.htpasswd
# (see container/production/podman-compose.yml).  NEVER commit real
# credentials; only the .example template is allowed through the
# negation below.  See docs/howto-webgui-htpasswd.md for the setup
# runbook.
acc-webgui.htpasswd
*.htpasswd
!acc-webgui.htpasswd.example
# Operator-edited deploy/.env may include API keys; cover the
# .bak the env/use.sh helper writes when overwriting it.
deploy/.env
deploy/.env.bak
# Allow .env.example AND every committed preset under env/.env.<model>.
!.env.example
!env/.env.*
*.egg-info/
dist/
build/
.venv/
venv/
*.pdf
docs/__pycache__/
.lancedb/
data/
# …but DO track the packaged built-in catalog metadata (day-0 Marketplace /
# Catalogs content; shipped as package-data, generated by tools/gen_builtin_catalog.py).
!acc/pkg/data/
!acc/pkg/data/**
acc/pkg/data/__pycache__/
*.wasm

# Internal documents — not for public distribution
docs/competitive-analysis.md
docs/PITCH_DECK.md
docs/STRATEGIC_PITCH.md
docs/PLAN_subagent_clustering.md

# Operator's Obsidian-vault docs.  Canonical home is
# C:\Users\micro\Documents\Notes\Notes\Development\AgenticCellCorpus\
# (Agent Communication\, ACC Implementation\, …).  If any are ever
# copied/symlinked into docs/ for cross-referencing, these patterns
# keep them local-only.
docs/Cell Communication *.md
docs/Agent Communication *.md
docs/ACC Implementation/
docs/[0-9][0-9][0-9] - *.md
test/results/

# Operator-local LLM test-result archive — see test/history/.gitignore
# for the per-dir rules.  Belt-and-braces top-level so a future
# directory rename doesn't accidentally publish private host data.
test/history/*
!test/history/.gitignore
!test/history/README.md

# Per-host acc-config.yaml overlays are now tracked (see
# deploy/host-configs/README.md).  Only sync backups are excluded —
# the in-tree deploy/host-configs/.gitignore handles those.

# Autoresearcher per-run outputs (E5).  Each run lands at
# runs/<topic-slug>-<YYYYMMDD>/ — gitignored so report drafts never
# leak into commits.
runs/

# Proposal 036 PR-2 — self-authored draft role packs stage under
# proposed/<scope>/<name>-<version>/ (role.yaml + role.md + accpkg.yaml)
# with the built candidate .accpkg alongside. Drafts are local until the
# operator reviews + promotes one (036 §8 Q3); never committed.
proposed/

# Operator dev tooling: controller-gen, kustomize, envtest binaries
# land here when the operator/Makefile downloads them. Refetched per
# developer.
operator/bin/

# Operator manifest mirror: build-time copy of repo-root roles/, skills/,
# mcps/ trees so `//go:embed` in
# operator/internal/reconcilers/manifests/ can reach them. Repopulated
# by `make sync-manifests`.
operator/internal/reconcilers/manifests/data/
schedules/*.yaml
!schedules/_example.yaml

# D-007 trusted-workspace mount root.  Project subdirectories created
# by operators at runtime (with their .acc-workspace-trust sentinels)
# are local-only; only the .gitkeep that guarantees the mount source
# exists is tracked.
workspaces/*
!workspaces/.gitkeep

# PR-X apply-request channel.  Runtime files are local-only; only the
# .gitkeep is tracked so the bind-mount source exists on a clean clone.
.acc-apply/*
!.acc-apply/.gitkeep

# Local file: catalog staged by `acc-deploy.sh flavour --local-catalog` (built
# unsigned control-roles/packs for dev/air-gap flavour builds). Runtime-built;
# only the .gitkeep is tracked so Containerfile.flavour's COPY source exists.
.acc-localcat/*
!.acc-localcat/.gitkeep

# Per-flavour deploy-time creds template emitted by `acc-deploy.sh flavour`
# (keys only, but regenerated each build — not source).
*.env.required

# Local on-demand KServe test-model CRs (ServingRuntime + InferenceService).
# Scratch for ad-hoc GPU model deploys during testing — synced by hand to acc1,
# never committed.
operator/config/samples/local-models/

# Local implementation plans / scratch design notes. Kept in-tree for
# convenient reference next to the code, but not for public distribution.
implementation/
