# ACC standalone deployment — environment variable overrides
# ─────────────────────────────────────────────────────────
# Copy this file to deploy/.env and fill in your values.
# .env is gitignored — never commit it with real secrets.
#
# Usage:
#   cp deploy/.env.example deploy/.env
#   # edit deploy/.env, then:
#   podman-compose --env-file deploy/.env up -d

# ── Phase 0b: Redis authentication ───────────────────────────────────────────
# Generate a strong password:
#   openssl rand -hex 32
#
# When empty, Redis starts without authentication.
# WARNING: leave empty only on isolated development networks.
REDIS_PASSWORD=

# ── Phase 0a: Ed25519 arbiter verify key ─────────────────────────────────────
# Base64-encoded raw 32-byte Ed25519 public key of the collective's arbiter.
# Generate a keypair:
#   python - <<'EOF'
#   import base64
#   from cryptography.hazmat.primitives.asymmetric.ed25519 import Ed25519PrivateKey
#   k = Ed25519PrivateKey.generate()
#   print("Private (keep secret):", base64.b64encode(k.private_bytes_raw()).decode())
#   print("Public  (set below):  ", base64.b64encode(k.public_key().public_bytes_raw()).decode())
#   EOF
#
# When empty, only signature presence is checked (not cryptographically verified).
ACC_ARBITER_VERIFY_KEY=

# ── LLM backend (optional overrides) ─────────────────────────────────────────
# ACC_LLM_BACKEND=anthropic
# ANTHROPIC_API_KEY=sk-ant-...
