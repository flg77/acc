# ACC Environment Variable Overrides
# Copy to .env and fill in values. Never commit .env.

# --- Deploy mode ---
# ACC_DEPLOY_MODE=standalone

# --- Agent identity ---
# ACC_AGENT_ROLE=ingester
# ACC_COLLECTIVE_ID=sol-01

# --- Signaling ---
# ACC_NATS_URL=nats://nats:4222

# --- Vector DB ---
# ACC_LANCEDB_PATH=/app/data/lancedb
# ACC_MILVUS_URI=http://milvus:19530
# ACC_MILVUS_COLLECTION_PREFIX=acc_

# --- LLM ---
# ACC_LLM_BACKEND=ollama
# ACC_OLLAMA_BASE_URL=http://ollama:11434
# ACC_OLLAMA_MODEL=llama3.2:3b
# ACC_ANTHROPIC_API_KEY=sk-ant-...
# ACC_ANTHROPIC_MODEL=claude-sonnet-4-6
# ACC_VLLM_INFERENCE_URL=http://vllm-svc:8000
# ACC_LLAMA_STACK_URL=http://llama-stack:5000

# --- Observability ---
# ACC_METRICS_BACKEND=log
# ACC_OTEL_SERVICE_NAME=acc-agent
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
