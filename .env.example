# ACC standalone deployment — environment-variable overrides.
#
# This is the operator's canonical .env template — lives at the repo
# root (podman-compose's native location).  Every container the
# acc-deploy.sh stack runs sources this file via `env_file: ../../.env`.
#
# Usage:
#   cp .env.example .env
#   $EDITOR .env                       # fill in values / API keys
#   ./acc-deploy.sh up
#
# Or pick a ready-made preset from env/ (vLLM / Anthropic / etc.):
#   ./env/use.sh                       # list available presets
#   ./env/use.sh anthropic             # copy that preset onto ./.env
#
# Or scaffold the file with:
#   ./acc-deploy.sh setup              # copies .env.example -> .env
#
# .env is gitignored — never commit it with real secrets.


# ── Redis authentication ─────────────────────────────────────────────────────
# Generate a strong password:
#   openssl rand -hex 32
#
# When empty, Redis starts without authentication.
# WARNING: leave empty only on isolated development networks.
REDIS_PASSWORD=

# ── Ed25519 arbiter verify key (proposal 011) ────────────────────────────────
# Base64-encoded raw 32-byte Ed25519 public key of the collective's arbiter.
# Generate a keypair:
#   python - <<'EOF'
#   import base64
#   from cryptography.hazmat.primitives.asymmetric.ed25519 import Ed25519PrivateKey
#   k = Ed25519PrivateKey.generate()
#   print("Private (keep secret):", base64.b64encode(k.private_bytes_raw()).decode())
#   print("Public  (set below):  ", base64.b64encode(k.public_key().public_bytes_raw()).decode())
#   EOF
#
# When empty, only signature presence is checked (not cryptographically verified).
ACC_ARBITER_VERIFY_KEY=

# ── Deploy mode (rare) ───────────────────────────────────────────────────────
# Overrides acc-config.yaml's deploy_mode.  Leave commented for standalone.
# ACC_DEPLOY_MODE=standalone           # standalone | edge | rhoai

# ── Signaling (rare — defaults work in-stack) ────────────────────────────────
# ACC_NATS_URL=nats://nats:4222

# ── LLM backend — the main operator-tunable surface ──────────────────────────
# These override the matching entries in acc-config.yaml.  See env/use.sh for
# ready-made presets per backend.
# ACC_LLM_BACKEND=anthropic            # ollama | openai_compat | anthropic | vllm | llama_stack
# ACC_LLM_MODEL=claude-sonnet-4-5
# ACC_LLM_BASE_URL=http://host.containers.internal:8001/v1
# ACC_LLM_TIMEOUT_S=120
# ACC_LLM_MAX_RETRIES=3
# ACC_LLM_API_KEY_ENV=ANTHROPIC_API_KEY

# Per-backend extras (still honoured for back-compat):
# ACC_OLLAMA_BASE_URL=http://ollama:11434
# ACC_OLLAMA_MODEL=llama3.2:3b
# ANTHROPIC_API_KEY=sk-ant-...
# ACC_ANTHROPIC_MODEL=claude-sonnet-4-6
# ACC_VLLM_INFERENCE_URL=http://vllm-svc:8000
# ACC_LLAMA_STACK_URL=http://llama-stack:5000

# ── Observability ────────────────────────────────────────────────────────────
# ACC_METRICS_BACKEND=log
# ACC_OTEL_SERVICE_NAME=acc-agent
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317

# ── acc-webgui auth (optional — only when --webgui is used) ──────────────────
# ACC_WEBGUI_AUTH_MODE=token           # token | htpasswd | oidc | mtls | oauth-proxy
# ACC_WEBGUI_OPERATOR_TOKEN=
# ACC_WEBGUI_VIEWER_TOKEN=
