# env/.env.anthropic
# =============================================================================
# Preset for hosted Anthropic Claude (production-grade quality; needs a
# paid API key).  Recommended for the autoresearcher demo since the
# report quality matters for thought-leadership use cases.
#
#     cp env/.env.anthropic deploy/.env
#     $EDITOR deploy/.env       # paste your sk-ant-... key
#     ./acc-deploy.sh up
# =============================================================================

ACC_COLLECTIVE_ID=sol-01
TUI=true
DETACH=true

ACC_LLM_BACKEND=anthropic
ACC_ANTHROPIC_API_KEY=sk-ant-replace-me
ACC_ANTHROPIC_MODEL=claude-sonnet-4-5

ACC_REDIS_URL=redis://acc-redis:6379

ACC_ROLES_ROOT=./roles
ACC_SKILLS_ROOT=./skills
ACC_MCPS_ROOT=./mcps

# --- Autoresearcher demo (recommended pairing) ---
# AUTORESEARCHER=true
# BRAVE_API_KEY=BSA-replace-me
# BROWSER_HARNESS_HEADLESS=true
# BROWSER_HARNESS_BACKEND=anthropic
# ACC_RESEARCH_MAX_ITERATIONS=3
# ACC_RESEARCH_CRITIC_THRESHOLD=0.70
# ACC_RESEARCH_ENABLE_PROMPT_PATCHES=true
# ACC_RESEARCH_MAX_RUN_TOKENS=250000
