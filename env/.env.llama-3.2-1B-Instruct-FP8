# env/.env.llama-3.2-1B-Instruct-FP8
# =============================================================================
# Preset for RedHatAI/Llama-3.2-1B-Instruct-FP8 served by vllmpunch
# (https://github.com/flg-redhat/vllmpunch).  Compact + fast; a good
# default for demoing both clustering examples on a developer laptop.
#
# Serve the model on the host before bringing the stack up:
#
#     vllm serve RedHatAI/Llama-3.2-1B-Instruct-FP8 \
#         --host 0.0.0.0 --port 8001
#
# Or via vllmpunch:
#
#     ./vllmpunch.sh up llama
#
# Then:
#
#     cp env/.env.llama-3.2-1B-Instruct-FP8 deploy/.env
#     # OR  ./env/use.sh llama-3.2-1B-Instruct-FP8
#     $EDITOR deploy/.env       # add API keys for autoresearcher demo
#     ./acc-deploy.sh up
# =============================================================================

ACC_COLLECTIVE_ID=sol-01
TUI=true
DETACH=true

ACC_LLM_BACKEND=openai_compat
ACC_OPENAI_BASE_URL=http://host.containers.internal:8001/v1
ACC_OPENAI_API_KEY=token-not-needed
ACC_OPENAI_MODEL=RedHatAI/Llama-3.2-1B-Instruct-FP8

ACC_REDIS_URL=redis://acc-redis:6379

ACC_ROLES_ROOT=./roles
ACC_SKILLS_ROOT=./skills
ACC_MCPS_ROOT=./mcps

# --- Autoresearcher demo (uncomment to activate) ---
# AUTORESEARCHER=true
# BRAVE_API_KEY=BSA-replace-me
# BROWSER_HARNESS_HEADLESS=true
# BROWSER_HARNESS_BACKEND=openai_compat
# ACC_RESEARCH_MAX_ITERATIONS=3
# ACC_RESEARCH_CRITIC_THRESHOLD=0.70
# ACC_RESEARCH_ENABLE_PROMPT_PATCHES=true
# ACC_RESEARCH_MAX_RUN_TOKENS=0
