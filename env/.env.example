# env/.env.example
# =============================================================================
# Canonical template — copy to deploy/.env directly OR pick a model-specific
# preset (env/.env.<model>) and copy that instead.
#
#     cp env/.env.example deploy/.env       # operator authors from scratch
#     ./env/use.sh llama-3.2-1B-Instruct-FP8     # picks the matching preset
#
# Every container's compose `env_file:` directive points at deploy/.env, so
# this is the file the runtime actually sources.
# =============================================================================


# -----------------------------------------------------------------------------
# Stack identity + acc-deploy.sh profiles
# -----------------------------------------------------------------------------

ACC_COLLECTIVE_ID=sol-01
TUI=true
DETACH=true
# CODING_SPLIT=true        # enables the coding-split-skills demo profile
# AUTORESEARCHER=true      # enables the autoresearcher demo profile
# MCP_ECHO=true            # diagnostic echo MCP server (smoke test only)


# -----------------------------------------------------------------------------
# LLM backend — pick exactly ONE block
# -----------------------------------------------------------------------------

# === Option A — local vLLM via openai_compat ===
# vLLM must bind to 0.0.0.0 (not 127.0.0.1) so the container bridge can
# reach it.  ``host.containers.internal`` is podman's alias for the host
# machine; fall back to the bridge IP when it doesn't resolve.
ACC_LLM_BACKEND=openai_compat
ACC_OPENAI_BASE_URL=http://host.containers.internal:8001/v1
ACC_OPENAI_API_KEY=token-not-needed
ACC_OPENAI_MODEL=RedHatAI/Llama-3.2-1B-Instruct-FP8

# === Option B — Anthropic API (hosted) ===
# ACC_LLM_BACKEND=anthropic
# ACC_ANTHROPIC_API_KEY=sk-ant-replace-me
# ACC_ANTHROPIC_MODEL=claude-sonnet-4-5

# === Option C — Ollama ===
# ACC_LLM_BACKEND=ollama
# ACC_OLLAMA_URL=http://host.containers.internal:11434
# ACC_OLLAMA_MODEL=llama3.1:8b


# -----------------------------------------------------------------------------
# Working memory + observability
# -----------------------------------------------------------------------------

# Redis is provisioned by acc-deploy.sh up; leave the URL alone unless you
# point the stack at an external Redis Enterprise cluster.
ACC_REDIS_URL=redis://acc-redis:6379

# Optional Redis password (empty = no auth — acceptable for local demos).
# REDIS_PASSWORD=


# -----------------------------------------------------------------------------
# Autoresearcher demo knobs (only meaningful with AUTORESEARCHER=true)
# -----------------------------------------------------------------------------

# Brave Search MCP — free tier 2k/month at https://brave.com/search/api/.
# BRAVE_API_KEY=BSA-replace-me

# Browser-harness — Playwright + LLM-driven.  HIGH risk in Cat-A.
# BROWSER_HARNESS_HEADLESS=true
# BROWSER_HARNESS_BACKEND=anthropic    # or openai_compat

# Iteration loop (E1)
# ACC_RESEARCH_MAX_ITERATIONS=3
# ACC_RESEARCH_CRITIC_THRESHOLD=0.70
# ACC_RESEARCH_ENABLE_PROMPT_PATCHES=true

# Cost cap (E1) — 0 means unset = no cap
# ACC_RESEARCH_MAX_RUN_TOKENS=0


# -----------------------------------------------------------------------------
# Roles + skills + MCP roots — override only when running outside the repo
# -----------------------------------------------------------------------------

ACC_ROLES_ROOT=./roles
ACC_SKILLS_ROOT=./skills
ACC_MCPS_ROOT=./mcps
