# env/.env.llama-3.2-3B-Instruct-FP8
# =============================================================================
# Preset for RedHatAI/Llama-3.2-3B-Instruct-FP8 served by vllmpunch
# (https://github.com/flg-redhat/vllmpunch).  Larger than the 1B preset
# (still FP8-quantised); a solid default when a beefier laptop / GPU
# is available.
#
# Serve the model on the host before bringing the stack up:
#
#     vllm serve RedHatAI/Llama-3.2-3B-Instruct-FP8 \
#         --host 0.0.0.0 --port 8022
#
# Or via vllmpunch:
#
#     ./vllmpunch.sh up llama-3b
#
# Then:
#
#     cp env/.env.llama-3.2-3B-Instruct-FP8 .env
#     # OR  ./env/use.sh llama-3.2-3B-Instruct-FP8
#     $EDITOR .env             # add API keys for autoresearcher demo
#     ./acc-deploy.sh up
# =============================================================================

ACC_COLLECTIVE_ID=sol-01
TUI=true
DETACH=true

# OpenAI-compatible vLLM backend.  The agent reads the universal
# ACC_LLM_BASE_URL / ACC_LLM_MODEL keys (overlay onto acc-config.yaml
# via acc.config._ENV_MAP) — NOT the legacy ACC_OPENAI_* names, which
# are not in the overlay map and would be silently ignored.
ACC_LLM_BACKEND=openai_compat
ACC_LLM_BASE_URL=http://host.containers.internal:8022/v1
ACC_LLM_MODEL=RedHatAI/Llama-3.2-3B-Instruct-FP8

# Local vLLM typically does not enforce a Bearer token; leave
# ACC_LLM_API_KEY_ENV unset to send the request unauthenticated.
# When using a hosted OpenAI-compat endpoint, set:
#   ACC_LLM_API_KEY_ENV=MY_KEY      # the NAME of the env var
#   MY_KEY=sk-...                    # the value the backend reads
# ACC_LLM_API_KEY_ENV=

ACC_REDIS_URL=redis://acc-redis:6379

ACC_ROLES_ROOT=./roles
ACC_SKILLS_ROOT=./skills
ACC_MCPS_ROOT=./mcps

# --- Autoresearcher demo (uncomment to activate) ---
# AUTORESEARCHER=true
# BRAVE_API_KEY=BSA-replace-me
# BROWSER_HARNESS_HEADLESS=true
# BROWSER_HARNESS_BACKEND=openai_compat
# ACC_RESEARCH_MAX_ITERATIONS=3
# ACC_RESEARCH_CRITIC_THRESHOLD=0.70
# ACC_RESEARCH_ENABLE_PROMPT_PATCHES=true
# ACC_RESEARCH_MAX_RUN_TOKENS=0
