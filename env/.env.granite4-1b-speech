# env/.env.granite4-1b-speech
# =============================================================================
# Preset for ibm-granite/granite-4.0-1b-speech served by vllmpunch on
# port 8001.  IBM Granite 4 speech-tuned variant — useful when you want
# to validate the agent fleet against a small IBM model rather than a
# Meta or Alibaba one.
#
# IMPORTANT: this preset binds 8001, the same port the Llama default
# uses.  Run only ONE model on 8001 at a time.  Switch presets by:
#
#     ./vllmpunch.sh down llama
#     ./vllmpunch.sh up granite4-1b-speech
#     cp env/.env.granite4-1b-speech deploy/.env
#     ./acc-deploy.sh down && ./acc-deploy.sh up
# =============================================================================

ACC_COLLECTIVE_ID=sol-01
TUI=true
DETACH=true

ACC_LLM_BACKEND=openai_compat
ACC_OPENAI_BASE_URL=http://host.containers.internal:8001/v1
ACC_OPENAI_API_KEY=token-not-needed
ACC_OPENAI_MODEL=ibm-granite/granite-4.0-1b-speech

ACC_REDIS_URL=redis://acc-redis:6379

ACC_ROLES_ROOT=./roles
ACC_SKILLS_ROOT=./skills
ACC_MCPS_ROOT=./mcps

# --- Autoresearcher demo (uncomment to activate) ---
# AUTORESEARCHER=true
# BRAVE_API_KEY=BSA-replace-me
# BROWSER_HARNESS_HEADLESS=true
# BROWSER_HARNESS_BACKEND=openai_compat
# ACC_RESEARCH_MAX_ITERATIONS=3
# ACC_RESEARCH_CRITIC_THRESHOLD=0.70
# ACC_RESEARCH_ENABLE_PROMPT_PATCHES=true
# ACC_RESEARCH_MAX_RUN_TOKENS=0
