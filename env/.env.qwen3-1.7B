# env/.env.qwen3-1.7B
# =============================================================================
# Preset for Qwen/Qwen3-1.7B served by vllmpunch on port 8002.
# Lean Alibaba Qwen3 base — useful when you want to compare another small
# model against the Llama default without changing ports.
#
# Serve on the host:
#
#     vllm serve Qwen/Qwen3-1.7B --host 0.0.0.0 --port 8002
#     # or:  ./vllmpunch.sh up qwen3
#
# Then:
#
#     cp env/.env.qwen3-1.7B deploy/.env
#     ./acc-deploy.sh up
# =============================================================================

ACC_COLLECTIVE_ID=sol-01
TUI=true
DETACH=true

ACC_LLM_BACKEND=openai_compat
ACC_OPENAI_BASE_URL=http://host.containers.internal:8002/v1
ACC_OPENAI_API_KEY=token-not-needed
ACC_OPENAI_MODEL=Qwen/Qwen3-1.7B

ACC_REDIS_URL=redis://acc-redis:6379

ACC_ROLES_ROOT=./roles
ACC_SKILLS_ROOT=./skills
ACC_MCPS_ROOT=./mcps

# --- Autoresearcher demo (uncomment to activate) ---
# AUTORESEARCHER=true
# BRAVE_API_KEY=BSA-replace-me
# BROWSER_HARNESS_HEADLESS=true
# BROWSER_HARNESS_BACKEND=openai_compat
# ACC_RESEARCH_MAX_ITERATIONS=3
# ACC_RESEARCH_CRITIC_THRESHOLD=0.70
# ACC_RESEARCH_ENABLE_PROMPT_PATCHES=true
# ACC_RESEARCH_MAX_RUN_TOKENS=0
