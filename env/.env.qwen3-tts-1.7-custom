# env/.env.qwen3-tts-1.7-custom
# =============================================================================
# Preset for Qwen/Qwen3-TTS-12Hz-1.7B-CustomVoice served by vllmpunch on
# port 8001.  Qwen3 TTS (text-to-speech) custom voice variant — primarily
# useful for ACC integrations that consume audio output rather than
# chat completions.
#
# WARNING: this is a TTS model, not a chat completion model.  Most of
# ACC's research / coding personas expect ChatCompletion-shaped responses
# and will NOT work against this endpoint without an adapter.  Bundled
# here for completeness with vllmpunch's models.json catalogue.
#
# Serve:
#
#     ./vllmpunch.sh up qwen3-tts-1.7-custom
#
# Then:
#
#     cp env/.env.qwen3-tts-1.7-custom deploy/.env
#     ./acc-deploy.sh up
# =============================================================================

ACC_COLLECTIVE_ID=sol-01
TUI=true
DETACH=true

ACC_LLM_BACKEND=openai_compat
ACC_OPENAI_BASE_URL=http://host.containers.internal:8001/v1
ACC_OPENAI_API_KEY=token-not-needed
ACC_OPENAI_MODEL=Qwen/Qwen3-TTS-12Hz-1.7B-CustomVoice

ACC_REDIS_URL=redis://acc-redis:6379

ACC_ROLES_ROOT=./roles
ACC_SKILLS_ROOT=./skills
ACC_MCPS_ROOT=./mcps

# Autoresearcher demo not recommended against a TTS endpoint — leave the
# AUTORESEARCHER profile off when using this preset.
