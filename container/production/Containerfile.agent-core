# ACC Agent Core — Production UBI10 Python 3.12 (multi-stage, CPU-only)
#
# Size strategy (see openspec/changes/20260609-agent-core-image-slimming):
#   - Multi-stage: a `builder` stage carries gcc + python3-devel to compile
#     C-extensions (lancedb); the final `runtime` stage copies only the
#     populated /opt/app-root site-packages — no compilers in the shipped image.
#   - CPU-only PyTorch: torch is installed from the CPU wheel index FIRST, so
#     sentence-transformers resolves against it and the ~2.7 GB nvidia/CUDA
#     payload is never pulled. The agent only uses embeddings on CPU; all LLM
#     inference is remote (in-cluster vLLM endpoint).
#   - Embedding model (all-MiniLM-L6-v2, 384-dim) is still baked in so the agent
#     starts with no network/egress dependency.
#   - Config is NOT baked in (always provided via volume mount or ConfigMap).
#
# Compatible with OpenShift restricted SCC (non-root UID 1001, g=u permissions).
#
# Build:
#   podman build -f container/production/Containerfile.agent-core \
#     --build-arg ACC_VERSION=0.2.0 \
#     -t localhost/acc-agent-core:0.2.0 .

# ============================================================================
# Stage 1 — builder: compile + install everything into /opt/app-root
# ============================================================================
FROM registry.access.redhat.com/ubi10/python-312-minimal:latest AS builder

USER 0

# OS-level build tools — needed only to build C-extension wheels (e.g. lancedb).
# These live ONLY in this stage and never reach the runtime image.
RUN microdnf install -y --nodocs \
        gcc \
        python3-devel \
    && microdnf clean all \
    && rm -rf /var/cache/dnf

WORKDIR /app

# ── CPU-only PyTorch FIRST ────────────────────────────────────────────────
# Installing torch from the CPU wheel index up front satisfies the
# sentence-transformers torch requirement without dragging in CUDA / nvidia-*
# wheels. This is the single largest size reduction.
RUN python3 -m pip install --no-cache-dir \
        --index-url https://download.pytorch.org/whl/cpu \
        torch

# ── Remaining Python dependencies (cache-friendly) ────────────────────────
# Copy ONLY pyproject.toml first so this layer rebuilds only when deps change.
# torch is already present (CPU), so sentence-transformers reuses it.
COPY pyproject.toml /app/pyproject.toml
RUN python3 -c "\
import tomllib, subprocess, sys;\
fh = open('/app/pyproject.toml', 'rb');\
data = tomllib.load(fh);\
fh.close();\
deps = data['project']['dependencies'];\
print('Installing pip dependencies:', deps);\
subprocess.run([sys.executable, '-m', 'pip', 'install', '--no-cache-dir'] + deps, check=True)\
"

# ── Bake embedding model (offline startup) ────────────────────────────────
ENV SENTENCE_TRANSFORMERS_HOME=/app/models \
    TRANSFORMERS_CACHE=/app/models
RUN for attempt in 1 2 3; do \
        python3 -c "\
from sentence_transformers import SentenceTransformer; \
SentenceTransformer('all-MiniLM-L6-v2', cache_folder='/app/models/all-MiniLM-L6-v2')" \
        && echo "Model download succeeded on attempt ${attempt}" && break; \
        echo "Attempt ${attempt} failed — waiting before retry..."; \
        sleep 10; \
    done

# ── Install the ACC package itself (no deps; they're already present) ──────
COPY acc/ /app/acc/
COPY regulatory_layer/ /app/regulatory_layer/
RUN python3 -m pip install --no-cache-dir --no-deps .

# ── OpenShell sandbox CLI (opt-in, proposal 051 Model 2) ──────────────────
# Install the `openshell` CLI (the [sandbox] extra) ONLY for a sandbox-capable
# agent image — it's alpha and needed solely when spec.sandbox is enabled, so
# the default image stays lean + free of the dependency. Build the sandbox
# flavour with `--build-arg WITH_SANDBOX=true`. The version comes from
# pyproject's [sandbox] extra (single source; no drift). Lands in /opt/app-root,
# copied wholesale into the runtime stage below.
ARG WITH_SANDBOX=false
RUN if [ "$WITH_SANDBOX" = "true" ]; then \
        python3 -c "import tomllib, subprocess, sys; \
deps = tomllib.load(open('/app/pyproject.toml','rb'))['project']['optional-dependencies']['sandbox']; \
print('Installing sandbox extra:', deps); \
subprocess.run([sys.executable, '-m', 'pip', 'install', '--no-cache-dir'] + deps, check=True)"; \
    fi

# ── Strip runtime-unnecessary weight before it reaches the runtime stage ───
# __pycache__ bytecode (~300 MB; regenerated lazily at runtime if needed),
# torch C++ headers and the bundled test suite — none used for CPU inference.
RUN find /opt/app-root -depth -type d -name __pycache__ -exec rm -rf {} + \
    && find /opt/app-root -type f -name '*.pyc' -delete \
    && rm -rf /opt/app-root/lib*/python3.12/site-packages/torch/test \
              /opt/app-root/lib*/python3.12/site-packages/torch/include

# ============================================================================
# Stage 2 — runtime: clean minimal base, no compilers
# ============================================================================
FROM registry.access.redhat.com/ubi10/python-312-minimal:latest

ARG ACC_VERSION=0.2.0

LABEL org.opencontainers.image.title="acc-agent-core" \
      org.opencontainers.image.description="Agentic Cell Corpus agent core (production UBI10, CPU-only)" \
      org.opencontainers.image.version="${ACC_VERSION}" \
      org.opencontainers.image.licenses="Apache-2.0" \
      org.opencontainers.image.base.name="registry.access.redhat.com/ubi10/python-312-minimal"

USER 0

# git — the agent shells out to `git` for the git_status / git_log_recent
# skills and for autonomous role.yaml commits via shell_exec.  Without it those
# capabilities fail at runtime (the rest of the agent still boots).
RUN microdnf install -y --nodocs git nano \
    && microdnf clean all \
    && rm -rf /var/cache/dnf
# Give "Open in $EDITOR" (Ecosystem role editor) a terminal editor that exists
# in the image — otherwise it fell back to `vi`, which isn't installed, and
# raised [Errno 2] (2026-06-22 report).  Operators can still override $EDITOR.
ENV EDITOR=nano

# Copy the fully-populated S2I app-root (all pip deps incl. the ACC package and
# CPU torch) and the baked embedding model from the builder. No gcc/devel here.
COPY --from=builder /opt/app-root /opt/app-root
COPY --from=builder /app/models /app/models

# Application source at the image-baked runtime paths the agent expects.
WORKDIR /app
COPY acc/ /app/acc/
COPY regulatory_layer/ /app/regulatory_layer/
# Skills + MCP manifests are NOT mounted by the compose (unlike roles/), so they
# must be baked in — otherwise the agent boots with an empty skill/MCP registry
# and every advertised capability (shell_exec, python_exec, fs_write,
# git_status, catalog_query, …) fails at runtime with SkillNotFoundError.
COPY skills/ /app/skills/
COPY mcps/ /app/mcps/
# models.yaml — the model registry + role→model map (B6, proposal 044).  Like
# skills/ + mcps/ above it is NOT mounted by the compose for agent services, so
# it must be baked: acc.models.apply_role_model_env() reads it at boot to bind a
# role to its mapped model.  Absent, the registry is empty, role_models never
# applies, and the agent silently falls to the global ACC_LLM_* default (the
# 29.6 lighthouse symptom: assistant stuck on the 3B model).  Operators can
# still override via a volume mount at /app/models.yaml or ACC_MODELS_PATH.
COPY models.yaml /app/models.yaml
COPY container/production/entrypoint.sh /app/entrypoint.sh

# cosign — the agent shells out to `cosign` to verify .accpkg signatures
# during an AccPackageInstall; without it any signed pack fails with
# CosignNotInstalled.  Bake the static binary in (mirrors the ttyd install
# in Containerfile.tui).
RUN python3 -c "import platform, urllib.request; m={'x86_64':'amd64','aarch64':'arm64'}.get(platform.machine(),'amd64'); urllib.request.urlretrieve(f'https://github.com/sigstore/cosign/releases/download/v2.4.1/cosign-linux-{m}', '/usr/local/bin/cosign')" \
    && chmod 0755 /usr/local/bin/cosign

# UID 1001 /etc/passwd entry (OpenShift restricted-SCC pattern: GID 0), data
# dirs, and group-writable perms.
RUN echo "acc:x:1001:0:ACC Agent:/app:/bin/sh" >> /etc/passwd \
    && mkdir -p \
        /app/data/lancedb/ingester \
        /app/data/lancedb/analyst \
        /app/data/lancedb/arbiter \
    && chown -R 1001:0 /app \
    && chmod -R g=u /app \
    && chmod 755 /app/entrypoint.sh

ENV SENTENCE_TRANSFORMERS_HOME=/app/models \
    TRANSFORMERS_CACHE=/app/models \
    HF_HUB_OFFLINE=1 \
    TRANSFORMERS_OFFLINE=1 \
    ACC_CONFIG_PATH=/app/acc-config.yaml \
    ACC_SKILLS_ROOT=/app/skills \
    ACC_MCPS_ROOT=/app/mcps \
    PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1

# Config must be provided at runtime (volume mount, ConfigMap, or ACC_* env).
# No default config is baked in — intentional.

USER 1001
ENTRYPOINT ["/app/entrypoint.sh"]
CMD ["python3", "-m", "acc.agent"]
