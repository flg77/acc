# ACC TUI — Production UBI10 Python 3.12 (minimal)
#
# Multi-screen operator console (ACC-TUI-Evolution).
#
# Fixes vs beta/Containerfile.tui:
#   - USER 0 held through pip install; non-root enforced only at the end
#   - COPY no longer requires README.md (which may not exist)
#   - Single USER 1001 instruction at the end (no duplicate)
#   - chown + chmod for OpenShift restricted SCC compliance (REQ-TUI-046)
#   - .containerignore required alongside this file
#   - Install lightweight core deps (pydantic, pyyaml, etc.) in addition to
#     textual+nats; without them acc.role_loader import fails silently (exit 1)
#   - pyproject.toml package-data includes *.tcss so pip install copies
#     app.tcss to site-packages (fixes silent FileNotFoundError in Textual)
#
# New in ACC-TUI-Evolution:
#   - ACC_COLLECTIVE_IDS env var (comma-separated, multi-collective — REQ-TUI-006)
#   - ACC_TUI_WEB_PORT env var (0 = disabled; non-zero = WebBridge — REQ-TUI-041)
#   - EXPOSE 8765 for WebBridge HTTP endpoint
#   - roles/ directory copied for dynamic role discovery (REQ-TUI-020, REQ-TUI-037)
#
# Compatible with OpenShift restricted SCC (non-root UID 1001 — REQ-TUI-046)
#
# Build:
#   podman build -f container/production/Containerfile.tui \
#     --build-arg ACC_VERSION=0.2.0 \
#     -t localhost/acc-tui:0.2.0 .
#
# Run standalone:
#   podman run -it --rm \
#     -e ACC_NATS_URL=nats://nats:4222 \
#     -e ACC_COLLECTIVE_IDS=sol-01 \
#     localhost/acc-tui:0.2.0
#
# Run with WebBridge:
#   podman run -it --rm \
#     -e ACC_NATS_URL=nats://nats:4222 \
#     -e ACC_COLLECTIVE_IDS=sol-01 \
#     -e ACC_TUI_WEB_PORT=8765 \
#     -p 8765:8765 \
#     localhost/acc-tui:0.2.0

FROM registry.access.redhat.com/ubi10/python-312-minimal:latest

ARG ACC_VERSION=0.2.0

LABEL org.opencontainers.image.title="acc-tui" \
      org.opencontainers.image.description="ACC terminal dashboard and role infusion UI (production UBI10)" \
      org.opencontainers.image.version="${ACC_VERSION}" \
      org.opencontainers.image.licenses="Apache-2.0" \
      org.opencontainers.image.base.name="registry.access.redhat.com/ubi10/python-312-minimal"

# Hold root for all install operations
USER 0

# ── Layer 1: Build tools (gcc needed by some Textual/Rich transitive deps) ───
RUN microdnf install -y --nodocs \
        gcc \
        python3-devel \
    && microdnf clean all \
    && rm -rf /var/cache/dnf

# ── Layer 2: Dependency install (no source yet — maximises layer caching) ────
# Copy pyproject.toml only; do NOT copy README.md (may not exist in all branches)
WORKDIR /app
COPY pyproject.toml /app/pyproject.toml

# Install [tui] extras (textual, rich) + lightweight core deps needed by the
# TUI import chain.  The chain is:
#   acc.tui.screens.infuse → acc.role_loader → acc.config → pydantic + pyyaml
#   acc.tui.client         → nats-py
#   acc.signals            → (stdlib only)
#
# Heavy ML/DB packages (lancedb, pymilvus, sentence-transformers, anthropic,
# opentelemetry-*) are NOT needed by any TUI code path and are excluded to
# keep the image small and the build fast.
#
# Uses \ line-continuation so the Containerfile parser joins all lines into
# one logical RUN argument before passing to /bin/sh — avoids the
# "unexpected EOF while looking for matching quote" build error.
RUN python3 -c "\
import tomllib, subprocess, sys;\
fh = open('/app/pyproject.toml', 'rb');\
data = tomllib.load(fh);\
fh.close();\
tui_deps = data['project']['optional-dependencies'].get('tui', []);\
print('Installing TUI dependencies:', tui_deps);\
subprocess.run([sys.executable, '-m', 'pip', 'install', '--no-cache-dir'] + tui_deps, check=True);\
core_deps = data['project']['dependencies'];\
HEAVY = ('lancedb', 'pymilvus', 'sentence-transformers', 'sentence_transformers', 'anthropic', 'opentelemetry');\
light_deps = [d for d in core_deps if not any(d.lower().startswith(h) for h in HEAVY)];\
print('Installing lightweight core dependencies:', light_deps);\
subprocess.run([sys.executable, '-m', 'pip', 'install', '--no-cache-dir'] + light_deps, check=True)\
"

# ── Layer 3: Application source ──────────────────────────────────────────────
COPY acc/ /app/acc/
# Copy roles/ directory for dynamic role discovery (REQ-TUI-020, REQ-TUI-037)
COPY roles/ /app/roles/
RUN pip install --no-cache-dir --no-deps . \
 && echo "acc:x:1001:0:ACC Agent:/app:/bin/sh" >> /etc/passwd \
 && chown -R 1001:0 /app \
 && chmod -R g=u /app

# Switch to non-root only here — after all installs and chown are complete
# UID 1001 satisfies OpenShift restricted SCC (REQ-TUI-046)
USER 1001

# WebBridge HTTP port (only active when ACC_TUI_WEB_PORT is set — REQ-TUI-041)
EXPOSE 8765

ENV ACC_NATS_URL=nats://nats:4222 \
    ACC_COLLECTIVE_IDS=sol-01 \
    ACC_TUI_WEB_PORT=0 \
    ACC_ROLES_ROOT=/app/roles \
    PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1

WORKDIR /app

CMD ["acc-tui"]
