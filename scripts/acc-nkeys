#!/usr/bin/env python3
"""acc-nkeys — generate NATS NKey identities for standalone ACC.

Proposal 013 (Phase 0c).  This is the standalone-mode counterpart to
the operator's in-cluster key generation: on rhoai/edge the operator
mints the NKey Secret and projects per-pod seeds; on a standalone
(Podman) host the operator runs this CLI by hand.

Subcommands
-----------

  generate     Mint the eight NKey identities, write each seed to a
               0600 file (seed-<identity>) and the public keys to
               public_keys.json, under --out-dir.

  render-conf  Read public_keys.json and emit a nats.conf containing
               the jetstream/http blocks plus the authorization block
               rendered from acc/nats_permissions.yaml.

Typical flow::

    ./scripts/acc-nkeys generate   --out-dir ./nkeys
    ./scripts/acc-nkeys render-conf --keys-dir ./nkeys --out ./nats.conf
    # mount nats.conf into the nats-server container (see
    # container/production/podman-compose.yml) and point each agent's
    # ACC_NKEY_SEED_PATH at its seed-<role> file.

Never commit the seed-* files or public_keys.json's seeds — they are
the collective's NATS credentials.
"""

from __future__ import annotations

import argparse
import json
import os
import stat
import sys
from pathlib import Path

# Allow running straight from a checkout without installing the pkg.
sys.path.insert(0, str(Path(__file__).resolve().parent.parent))

from acc.nkeys import (  # noqa: E402
    NKEY_IDENTITIES,
    generate_identity_keys,
    render_authorization_block,
)

_PUBLIC_KEYS_FILE = "public_keys.json"


def _seed_filename(identity: str) -> str:
    return f"seed-{identity}"


def cmd_generate(args: argparse.Namespace) -> int:
    out_dir = Path(args.out_dir)
    out_dir.mkdir(parents=True, exist_ok=True)

    # Refuse to clobber an existing key set — regenerating would lock
    # every already-connected client out of the bus (same invariant
    # the operator enforces on its Secret).
    existing = [
        _seed_filename(i) for i in NKEY_IDENTITIES
        if (out_dir / _seed_filename(i)).exists()
    ]
    if existing and not args.force:
        print(
            f"acc-nkeys: {len(existing)} seed file(s) already exist in "
            f"{out_dir} — refusing to overwrite (rotating keys locks "
            f"out running clients).  Pass --force only for a deliberate "
            f"rotation followed by a restart of every ACC process.",
            file=sys.stderr,
        )
        return 1

    keys = generate_identity_keys()
    public_keys = {i: keys[i]["public"] for i in NKEY_IDENTITIES}

    for identity in NKEY_IDENTITIES:
        seed_path = out_dir / _seed_filename(identity)
        seed_path.write_text(keys[identity]["seed"] + "\n", encoding="ascii")
        os.chmod(seed_path, stat.S_IRUSR | stat.S_IWUSR)  # 0600

    pub_path = out_dir / _PUBLIC_KEYS_FILE
    pub_path.write_text(
        json.dumps(public_keys, indent=2, sort_keys=True) + "\n",
        encoding="ascii",
    )

    print(f"acc-nkeys: wrote {len(NKEY_IDENTITIES)} seed files + "
          f"{_PUBLIC_KEYS_FILE} to {out_dir}")
    print("acc-nkeys: point each ACC process at its seed via "
          "ACC_NKEY_ENABLED=true ACC_NKEY_SEED_PATH=<path>")
    return 0


def cmd_render_conf(args: argparse.Namespace) -> int:
    keys_dir = Path(args.keys_dir)
    pub_path = keys_dir / _PUBLIC_KEYS_FILE
    if not pub_path.is_file():
        print(f"acc-nkeys: {pub_path} not found — run `acc-nkeys "
              f"generate` first", file=sys.stderr)
        return 1
    public_keys = json.loads(pub_path.read_text(encoding="ascii"))

    auth_block = render_authorization_block(public_keys)
    conf = (
        "# nats.conf - generated by scripts/acc-nkeys (proposal 013).\n"
        "# Regenerate after `acc-nkeys generate`; do not hand-edit the\n"
        "# authorization block - it is derived from "
        "acc/nats_permissions.yaml.\n\n"
        "jetstream {\n"
        "  store_dir: /data/jetstream\n"
        "}\n\n"
        "http: 8222\n\n"
        + auth_block
    )

    if args.out == "-":
        sys.stdout.write(conf)
    else:
        Path(args.out).write_text(conf, encoding="utf-8")
        print(f"acc-nkeys: wrote {args.out}")
    return 0


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        prog="acc-nkeys", description=__doc__,
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    sub = parser.add_subparsers(dest="command", required=True)

    gen = sub.add_parser("generate", help="mint the eight NKey identities")
    gen.add_argument("--out-dir", default="./nkeys",
                     help="directory for seed-* files (default: ./nkeys)")
    gen.add_argument("--force", action="store_true",
                     help="overwrite an existing key set (rotation only)")
    gen.set_defaults(func=cmd_generate)

    ren = sub.add_parser("render-conf", help="emit nats.conf with auth block")
    ren.add_argument("--keys-dir", default="./nkeys",
                     help="directory holding public_keys.json")
    ren.add_argument("--out", default="./nats.conf",
                     help="output path, or '-' for stdout")
    ren.set_defaults(func=cmd_render_conf)
    return parser


def main(argv: list[str] | None = None) -> int:
    args = build_parser().parse_args(argv)
    return args.func(args)


if __name__ == "__main__":
    raise SystemExit(main())
